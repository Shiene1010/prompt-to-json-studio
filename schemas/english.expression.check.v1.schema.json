{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "English Expression Check Schema v1",
    "type": "object",
    "properties": {
        "service_key": {
            "type": "string",
            "const": "english.expression.check"
        },
        "schema_version": {
            "type": "integer",
            "const": 1
        },
        "domain": {
            "type": "string",
            "const": "education"
        },
        "status": {
            "type": "string",
            "enum": [
                "ready",
                "clarify",
                "unsupported",
                "error"
            ]
        },
        "slots": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string"
                },
                "context": {
                    "type": "string",
                    "description": "e.g., 'formal meeting'"
                },
                "user_intent": {
                    "type": "string"
                }
            },
            "required": [
                "text"
            ]
        },
        "missing_slots": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "message": {
            "type": "string"
        }
    },
    "required": [
        "service_key",
        "schema_version",
        "domain",
        "status",
        "slots"
    ]
}